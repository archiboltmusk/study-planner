VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay (publishable key only — safe for frontend)
# Get from: https://dashboard.razorpay.com → Settings → API Keys
VITE_RAZORPAY_KEY_ID=rzp_test_...

# Razorpay secrets — set as Supabase Edge Function secrets, NEVER in frontend
# RAZORPAY_WEBHOOK_SECRET comes from Dashboard → Webhooks (point the webhook at
# the razorpay-webhook edge function; enable refund.* events)
# supabase secrets set RAZORPAY_KEY_ID=rzp_live_... RAZORPAY_KEY_SECRET=... RAZORPAY_WEBHOOK_SECRET=... SUPABASE_SERVICE_ROLE_KEY=...
