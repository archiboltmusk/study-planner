VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay (publishable key only — safe for frontend)
# Get from: https://dashboard.razorpay.com → Settings → API Keys
VITE_RAZORPAY_KEY_ID=rzp_test_...

# Razorpay secret — set as Supabase Edge Function secret, NEVER in frontend
# supabase secrets set RAZORPAY_KEY_ID=rzp_live_... RAZORPAY_KEY_SECRET=... SUPABASE_SERVICE_ROLE_KEY=...

# AI provider for daily questions — at least one required
# Free options (recommended):
GEMINI_API_KEY=         # https://aistudio.google.com → Get API key (free, 1500 req/day)
GROQ_API_KEY=           # https://console.groq.com → API Keys (free, Llama 3.3 70B)
# Paid fallback:
ANTHROPIC_API_KEY=sk-ant-api03-...

CRON_SECRET=some-random-secret-string
